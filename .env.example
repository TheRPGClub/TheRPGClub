# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5

# Local PostgreSQL development database
RPGCLUB_DATABASE_NAME=rpgclub_api_development
RPGCLUB_DATABASE_USERNAME=admin
RPGCLUB_DATABASE_PASSWORD=change_me
RPGCLUB_DATABASE_HOST=127.0.0.1
RPGCLUB_DATABASE_PORT=5432

# Neon/production. When present, Rails uses this before the local settings above.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# API auth for service clients such as the Discord bot.
RPGCLUB_BOT_API_TOKEN=change_me_to_a_long_random_token

# Browser auth through Discord OAuth.
DISCORD_CLIENT_ID=your_numeric_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
DISCORD_OAUTH_SUCCESS_REDIRECT=http://localhost:3001
DISCORD_OAUTH_SCOPES=identify email guilds

# Next.js/frontend CORS.
RPGCLUB_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cookie session settings. Use none/true behind HTTPS in production.
RPGCLUB_SESSION_SAME_SITE=lax
RPGCLUB_SESSION_SECURE=false
